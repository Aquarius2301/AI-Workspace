{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=AIWorkspace;Trusted_Connection=True;"
  },
  "AuthSetting": {
    "JwtKey": "YourJwtKey",
    "Issuer": "AiWorkspace",
    "Audience": "AiWorkspaceClients",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  },
  "UploadSetting": {
    "PublicKey": "PublicKey",
    "PrivateKey": "PrivateKey",
    "UrlEndpoint": "UrlEndpoint"
  },
  "RateLimitSetting": {
    "PermitLimit": 5,
    "WindowMinutes": 1
  },
  "FrontendSetting": {
    "Url": "http://localhost:5173"
  }
}
