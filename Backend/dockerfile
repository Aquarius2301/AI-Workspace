# Build stage
FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

# Copy solution and project files for restore
COPY Backend/AIWorkspace.sln .
COPY Backend/BusinessObject/BusinessObject.csproj BusinessObject/
COPY Backend/DataAccess/DataAccess.csproj DataAccess/
COPY Backend/Infrastructure/Infrastructure.csproj Infrastructure/
COPY Backend/WebApi/WebApi.csproj WebApi/

# Restore dependencies
RUN dotnet restore AIWorkspace.sln

# Copy all backend source code
COPY Backend/ .

# Build and publish
WORKDIR /src/WebApi
RUN dotnet publish -c Release -o /app/publish --no-restore

# Runtime stage
FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS runtime
WORKDIR /app
EXPOSE 80
EXPOSE 443
COPY --from=build /app/publish .
ENTRYPOINT ["dotnet", "WebApi.dll"]