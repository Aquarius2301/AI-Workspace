{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "YourDatabase"
  },
  "AuthSetting": {
    "JwtKey": "YourJwtKey",
    "Issuer": "AiWorkspace",
    "Audience": "AiWorkspaceClients",
    "AccessTokenMinutes": 2,
    "RefreshTokenDays": 30,
    "AllowInsecureCookies": true,
    "CookieDomain": null
  }
}
